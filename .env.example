# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Browser mode: "local" uses Playwright directly, "browserbase" uses remote cloud browser
BROWSER_MODE=local
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Google Sheets (optional — for syncing job pipeline visibility)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./data/google-service-account.json

# Data paths
DB_PATH=./data/jobs.db
PROFILE_PATH=./data/profile.json

# Logging
LOG_LEVEL=info
